{
  "name": "intercept-mcp",
  "version": "4.1.1",
  "description": "MCP server with multi-tier fallback chain for fetching web content as clean markdown",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "intercept-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "fetch",
    "search",
    "web",
    "markdown",
    "claude",
    "youtube",
    "wikipedia",
    "github",
    "cloudflare",
    "turndown",
    "searxng"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bighippoman/intercept-mcp.git"
  },
  "mcpName": "io.github.bighippoman/intercept-mcp",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@truto/turndown-plugin-gfm": "^1.0.2",
    "duck-duck-scrape": "^2.2.7",
    "got-scraping": "^4.2.1",
    "linkedom": "^0.18.12",
    "pdf-parse": "^2.4.5",
    "turndown": "^7.2.4",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^25.3.3",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
