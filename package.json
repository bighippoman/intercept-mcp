{
  "name": "intercept-mcp",
  "version": "3.0.9",
  "description": "MCP server with multi-tier fallback chain for fetching web content as clean markdown",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "intercept-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "fetch",
    "jina",
    "web",
    "markdown",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bighippoman/intercept-mcp.git"
  },
  "mcpName": "io.github.bighippoman/intercept-mcp",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mozilla__readability": "^0.4.2",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
